generator client {
  provider = "prisma-client"
  output   = "./src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model ChatSession {
  id         String   @id @default(uuid())
  userId     String
  createdAt  DateTime @default(now())
  sessionURI String   @default(cuid())
  summary    String

  @@index([userId], map: "ChatSession_userId_fkey")
}

model Message {
  id            String      @id @default(uuid())
  role          MessageRole
  content       String      @db.Text
  createdAt     DateTime    @default(now())
  chatSessionId String

  @@index([chatSessionId], map: "Message_chatSessionId_fkey")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique(map: "User_email_key")
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MessageRole {
  USER
  ASSISTANT
}
